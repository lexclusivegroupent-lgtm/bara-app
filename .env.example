# ──────────────────────────────────────────────────────────────
# Bära — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── NODE ENV ───────────────────────────────────────────────────
# REQUIRED. Set to "production" on Railway/any live server.
# Controls security mode, rate limiting, and token exposure.
NODE_ENV=production

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (provided by Railway/Neon/Supabase etc.)
DATABASE_URL=postgresql://user:password@host:5432/bara_db

# ── AUTHENTICATION ─────────────────────────────────────────────
# REQUIRED in production. Random 32+ character secret for signing JWTs.
# Generate with:  openssl rand -hex 32
# The server will REFUSE to start in production without a real value.
JWT_SECRET=change_me_to_a_long_random_secret

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# Example: https://bara.app,https://www.bara.app
# If not set, all origins are allowed (logs a warning in production).
CORS_ORIGIN=https://your-app-domain.com

# ── ADMIN API ──────────────────────────────────────────────────
# REQUIRED in production. Key for GET /api/admin/stats
# Pass as x-admin-key header or ?key= query param.
# The endpoint is DISABLED in production if this is not set or uses the default.
# Generate with:  openssl rand -hex 16
ADMIN_STATS_KEY=change_me_to_a_secure_key

# ── PHOTO STORAGE (Cloudinary) ────────────────────────────────
# REQUIRED for photo uploads. Free tier: 25 GB storage + 25 GB bandwidth/month.
# Setup:
#   1. Create a free account at https://cloudinary.com
#   2. Find your Cloud Name in the Cloudinary dashboard
#   3. Create an unsigned upload preset: Settings → Upload → Upload presets → Add
#      Set "Signing mode" to "Unsigned", folder to "bara"
#   4. Set both values below
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=bara_uploads

# ── EMAIL (Resend) ────────────────────────────────────────────
# Required for password reset emails to actually be sent.
# Without this, reset tokens are only visible in server logs.
# Free tier: 3,000 emails/month at https://resend.com
# Setup:
#   1. Create a free account at https://resend.com
#   2. Add and verify your sending domain (e.g. bara.se)
#   3. Create an API key under API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Bära <noreply@bara.se>

# ── APP BASE URL (for password reset links) ───────────────────
# The public URL of your deployed app — used to build reset password links.
# For Expo web: your Railway/deployment domain. For native: your deep link domain.
APP_BASE_URL=https://your-app-domain.com

# ── MAPS & DISTANCE (Google Maps) ────────────────────────────
# REQUIRED for real distance/pricing calculation.
# Without this, the distance endpoint returns a 503 error (no silent random fallback).
# The $200/month free credit covers ~40,000 geocoding calls — free at MVP scale.
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Enable "Geocoding API"
#   3. Create a server-side API key (restrict to your server IP for security)
GOOGLE_MAPS_KEY=your_server_side_google_maps_key

# ── EXPO APP DOMAIN ────────────────────────────────────────────
# The base domain for your API, used by the Expo app to make requests.
# In Replit dev: your REPLIT_DEV_DOMAIN + artifact path
# In production: your Railway API domain
EXPO_PUBLIC_DOMAIN=your-api.railway.app
