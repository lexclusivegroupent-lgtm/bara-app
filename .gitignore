# =============================================================
# Bära — .gitignore
# =============================================================

# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log

# Environment variables — NEVER commit real secrets
.env
.env.local
.env.development
.env.production
.env.staging
*.env

# Build output
dist/
build/
out/
static-build/
web-build/

# Expo / React Native
.expo/
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/settings.json
.idea/
*.swp
*.swo
.nvmrc

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
.cache/

# Replit-specific
.replit
replit.nix
.local/
replit.md

# Railway / deployment
.railway/

# Cloudinary upload presets (contain secrets)
cloudinary-credentials.json
