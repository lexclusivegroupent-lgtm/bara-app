# ──────────────────────────────────────────────────────────────
# Bära — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (provided by Railway/Neon/Supabase etc.)
DATABASE_URL=postgresql://user:password@host:5432/bara_db

# ── AUTHENTICATION ─────────────────────────────────────────────
# Random 32+ character secret for signing JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# ── ADMIN API ──────────────────────────────────────────────────
# Key required to access GET /api/admin/stats
# Pass as x-admin-key header or ?key= query param
ADMIN_STATS_KEY=bara-admin-2025

# ── GOOGLE MAPS (optional) ─────────────────────────────────────
# Required for address geocoding and distance calculation
# Without this, a default 10 km estimate is used
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ── EXPO APP DOMAIN ────────────────────────────────────────────
# The base domain for your API (no trailing slash)
# In Replit: your REPLIT_DEV_DOMAIN + artifact path
EXPO_PUBLIC_DOMAIN=your-app.railway.app

# ── EMAIL / SMTP (optional — for password reset emails) ────────
# If not set, the app runs in dev mode and prints reset tokens to console
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=noreply@bara.se

# ── NODE ENV ───────────────────────────────────────────────────
NODE_ENV=production
