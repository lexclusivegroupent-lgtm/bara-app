# =============================================================
# Bära — Root Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real values to version control.
# =============================================================

# --- API Server (artifacts/api-server/.env) ---

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/bara_db

# JWT secret for signing tokens — use a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars

# Admin dashboard access key — shown at /api/admin
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
BARA_ADMIN_KEY=replace_with_random_hex_string

# Secondary stats endpoint key
ADMIN_STATS_KEY=replace_with_random_hex_string

# Production URL of the deployed app (no trailing slash)
APP_BASE_URL=https://app.baraapp.se

# --- Cloudinary (file/photo uploads) ---
# Get these from: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Resend (transactional email) ---
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Verified sender email address
RESEND_FROM_EMAIL=hello@yourdomain.se

# --- Mobile App (artifacts/bara/.env) ---

# Domain where the API server is hosted (no https://, no trailing slash)
# Example: my-api.railway.app  or  api.baraapp.se
EXPO_PUBLIC_DOMAIN=your-railway-api-domain.railway.app

# Google Maps API key — enable Maps SDK + Places API in Google Cloud Console
# https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza_your_google_maps_api_key

# --- GitHub Actions Secrets (set in repo Settings > Secrets > Actions) ---
# These are only needed for CI/CD — do NOT put them in any .env file

# Railway API token for automatic deployment
# Get from: https://railway.app/account/tokens
# RAILWAY_TOKEN=your_railway_token  # → set as GitHub secret, not here
