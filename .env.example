# ============================================================
# Bära — Environment Variables Reference
# Copy this file to .env and fill in the actual values.
# NEVER commit .env with real secrets to version control.
# ============================================================


# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string (Replit provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/bara_db


# ─── Auth ───────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# Generate a strong random value: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long


# ─── Maps / Location ────────────────────────────────────────
# Google Maps API key (used by the Expo app for map rendering).
# Enable: Maps SDK for Android, Maps SDK for iOS, Maps JavaScript API
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key


# ─── Expo / Domain ──────────────────────────────────────────
# The public domain of your deployment (set automatically on Replit).
# In production this will be your .replit.app domain.
EXPO_PUBLIC_DOMAIN=your-replit-dev-domain.replit.dev


# ─── Admin ──────────────────────────────────────────────────
# Secret key to access the admin stats endpoint:
#   GET /api/admin/stats?key=<ADMIN_STATS_KEY>
#   or: x-admin-key: <ADMIN_STATS_KEY> header
# Defaults to "bara-admin-2025" if not set (change this in production!)
ADMIN_STATS_KEY=your-admin-stats-secret-key


# ─── Node ───────────────────────────────────────────────────
NODE_ENV=production
