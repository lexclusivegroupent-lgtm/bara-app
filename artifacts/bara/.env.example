# =============================================================
# Bära Mobile App — Environment Variables
# Copy to artifacts/bara/.env for local development.
# All EXPO_PUBLIC_ variables are bundled into the client.
# =============================================================

# Domain where your API server is running (no https://, no trailing slash)
# Local:      localhost:8080
# Production: your-service.railway.app
EXPO_PUBLIC_DOMAIN=localhost:8080

# Google Maps API key (enable Maps SDK + Places API in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza_your_google_maps_api_key
